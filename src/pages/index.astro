---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import EducationCard from '@/components/home/EducationCard.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'
import nudtBadge from '@/assets/nudt.png'


const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full p-1 avatar-wiggle cursor-pointer'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>Developer / M.S.E.</p>
        <p class='text-muted-foreground'>
            Postgraduate in Information and Communication Engineering at the National University of Defense Technology, 
            with research interests in Cross-Modal Vision-Language Understanding, 
            and passionate about web development, application design, and hardware projects with microcontrollers.
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>

      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }
      <Section title='Education'>
        <div class='flex flex-col gap-y-3'>
          <EducationCard
            school='National University of Defense Technology'
            program='Information and Communication Engineering'
            period='August 2025 - Present'
            badgeImage={nudtBadge.src}
            link="https://www.nudt.edu.cn/"
          />
          <EducationCard
            school='National University of Defense Technology'
            program='Information Engineering'
            period='August 2021 - July 2025'
            badgeImage={nudtBadge.src}
            link="https://www.nudt.edu.cn/"
          />
        </div>
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>

<style>
@keyframes wiggle {
  0% { transform: scale(1); }
  20% { transform: scale(1.3); }
  40% { transform: scale(1.3) rotate(-8deg); }
  60% { transform: scale(1.3) rotate(8deg); }
  80% { transform: scale(1.3) rotate(-8deg); }
  100% { transform: scale(1) rotate(0deg); }
}
.avatar-wiggle:hover {
  animation: wiggle 0.6s ease-in-out;
}
</style>
